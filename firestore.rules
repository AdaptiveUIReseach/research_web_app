rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null;
      
      // Legacy paths (keeping for backward compatibility)
      match /events/{eventId} {
        allow read, write: if request.auth != null;
      }
      match /metrics/{metricId} {
        allow read, write: if request.auth != null;
      }
      
      // New game structure - allow games collection and its documents
      match /games/{gameId} {
        allow read, write: if request.auth != null;
        
        // Raw events subcollection
        match /raw_events/{eventId} {
          allow read, write: if request.auth != null;
        }
      }
    }
    
    match /models/{modelId} {
      allow read: if true;
      allow write: if false;
    }

    // Explicitly allow collectionGroup queries for raw_events
    // This is required for the 'Inspect Nodes' / Raw Logs view
    match /{path=**}/raw_events/{eventId} {
      allow read: if request.auth != null;
    }
  }
}
